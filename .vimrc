" colorscheme
set background=light

" line numbering
set number

" Better display for messages
set cmdheight=2
" Smaller updatetime for CursorHold & CursorHoldI
set updatetime=300
" don't give |ins-completion-menu| messages.
set shortmess+=c
" always show signcolumns
set signcolumn=yes

set tabstop=8
set softtabstop=0
set expandtab
set shiftwidth=4
set smarttab

