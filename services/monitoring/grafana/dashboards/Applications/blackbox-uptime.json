      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "(probe_ssl_earliest_cert_expiry{job=~\"$job\"} - time()) / 86400",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
