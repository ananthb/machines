# vim: set filetype=yaml:

window:
  dimensions:
    columns: 80
    lines: 24

  dynamic_title: true

font:
  size: 16.0

selection:
  save_to_clipboard: true

live_config_reload: true

shell:
  program: /opt/homebrew/bin/fish
  args:
    - -l
    - -i
    - -c
    - "/opt/homebrew/bin/tmux attach -t main || /opt/homebrew/bin/tmux new-session -t main"
