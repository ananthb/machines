# vim: set filetype=yaml:

window:
  dimensions:
    columns: 100
    lines: 30

  dynamic_title: true

font:
  size: 16.0

selection:
  save_to_clipboard: true

live_config_reload: true

shell:
  program: /usr/local/bin/fish
  args:
    - -l
    - -i
    - -c 
    - "/usr/local/bin/tmux attach -t main || /usr/local/bin/tmux new-session -t main"
