[include]
  path = local # local isn't version controlled
  path = sys
  path = user

[core]
  pager = delta

[user]
  useConfigOnly = true

[alias]
  a = add
  b = branch
  c = commit
  p = push
  r = reset
  s = status -sb
  sw = switch
  co = checkout
  cp = cherry-pick

[init]
  defaultBranch = main

[color]
  ui = true
  diff = auto
  status = auto
  branch = auto

[advice]
  pushNonFastForward = false
  statusHints = false
  commitBeforeMerge = false
  resolveConflict = false
  implicitIdentity = false
  detachedHead = false

[help]
  autoCorrect = 0

[commit]
  gpgsign = true

[tag]
  gpgsign = true

[gpg.x509]
  program = gitsign

[gpg]
  format = x509

[pull]
  ff = only

[push]
  autoSetupRemote = true
[rerere]
	enabled = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[merge]
	conflictStyle = zdiff3
[diff]
	algorithm = histogram
[transfer]
	fsckObjects = true
[fetch]
	fsckObjects = true
[receive]
	fsckObjects = true
[http]
	postBuffer = 157286400
