[core]
  autocrlf = input

[alias]
  a = add
  b = branch
  c = commit
  p = push
  r = reset
  s = status -sb
  co = checkout
  cp = cherry-pick

[init]
  defaultBranch = main

[color]
  ui = true
  diff = auto
  status = auto
  branch = auto

[advice]
  pushNonFastForward = false
  statusHints = false
  commitBeforeMerge = false
  resolveConflict = false
  implicitIdentity = false
  detachedHead = false

[help]
  autoCorrect = 10

[commit]
  gpgsign = true

[tag]
  gpgsign = true

[include]
  path = local # local isn't version controlled
  path = sys
  path = user

[pull]
  ff = only

[filter "lfs"]
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
