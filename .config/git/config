[color]
    ui = true
    diff = auto
    status = auto
    branch = auto

[advice]
    pushNonFastForward = false
    statusHints = false
    commitBeforeMerge = false
    resolveConflict = false
    implicitIdentity = false
    detachedHead = false

[core]
	autocrlf = input

[include]
    path = ./local

[http]
	postBuffer = 524288000

[commit]
	gpgsign = true

[url "ssh://git@github.com/"]
        insteadOf = https://github.com/
