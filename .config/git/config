[init]
    defaultBranch = main

[color]
    ui = true
    diff = auto
    status = auto
    branch = auto

[advice]
    pushNonFastForward = false
    statusHints = false
    commitBeforeMerge = false
    resolveConflict = false
    implicitIdentity = false
    detachedHead = false

[core]
    autocrlf = input

[commit]
    gpgsign = true

[include]
    path = id
    path = gh_ssh_urls

[pull]
    ff = only

[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
