[core]
    autocrlf = input

[init]
    defaultBranch = main

[color]
    ui = true
    diff = auto
    status = auto
    branch = auto

[advice]
    pushNonFastForward = false
    statusHints = false
    commitBeforeMerge = false
    resolveConflict = false
    implicitIdentity = false
    detachedHead = false

[help]
  autoCorrect = prompt

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = "~/.config/git/allowed_signers"

[commit]
    gpgsign = true

[tag]
  gpgsign = true

[include]
    path = user
    path = gh_ssh_urls

[pull]
    ff = only

[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
