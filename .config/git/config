[include]
  path = local # local isn't version controlled
  path = sys
  path = user

[core]
  autocrlf = input
	pager = delta

[user]
  useConfigOnly = true

[alias]
  a = add
  b = branch
  c = commit
  p = push
  r = reset
  s = status -sb
  co = checkout
  cp = cherry-pick

[init]
  defaultBranch = main

[color]
  ui = true
  diff = auto
  status = auto
  branch = auto

[advice]
  pushNonFastForward = false
  statusHints = false
  commitBeforeMerge = false
  resolveConflict = false
  implicitIdentity = false
  detachedHead = false

[help]
  autoCorrect = 0

[commit]
  gpgsign = true
	verbose = true

[tag]
  gpgsign = true

[pull]
  ff = only

[push]
  autoSetupRemote = true
[rerere]
	enabled = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[merge]
	conflictStyle = zdiff3
[diff]
	algorithm = histogram
[transfer]
	fsckObjects = true
[fetch]
	fsckObjects = true
[receive]
	fsckObjects = true
