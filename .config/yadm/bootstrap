#!/bin/bash

if command -v nvim >/dev/null 2>&1; then
  # download vim plug
  plug_vim="$HOME/.config/nvim/autoload/plug.vim"
  if [[ ! -f "$plug_vim" ]]; then
    echo "Downloading vim-plug for neovim"
    curl --create-dirs -fsSLo "$plug_vim" https://raw.github.com/junegunn/vim-plug/master/plug.vim
  fi

  # make neovim pyvenv
  pyvenv="$HOME/.local/share/nvim/pyvenv"
  if [[ ! -f "$pyvenv/bin/python" ]]; then
    python -m venv "$pyvenv"
  fi

  # install and update everything
  "$pyvenv"/bin/pip install --quiet --upgrade pyvenv
  nvim '+PlugUpgrade' '+PlugClean!' '+PlugUpdate' '+GoInstallBinaries' \
    '+qall'
fi

if command -v tmux >/dev/null 2>&1; then
  tpm="$HOME/.config/tmux/plugins/tpm"
  if [[ ! -d "$tpm" ]]; then
    git clone https://github.com/tmux-plugins/tpm "$tpm"
  fi
fi

# install Hack Nerd Font
case "$OSTYPE" in
  darwin*)
    brew tap --quiet homebrew/cask-fonts
    brew install --quiet --cask font-hack-nerd-font
    ;;
  linux*)
    if ! fc-list | grep -wq 'Hack Nerd Font'; then
      mkdir -p ~/.local/share/fonts
      cd ~/.local/share/fonts || exit 1
      hack="https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/Hack"
      variants=("Bold" "BoldItalic" "Italic" "Regular")
      for v in "${variants[@]}"; do
        ttf="Hack %v Nerd Font Complete.ttf"
        url="$hack/complete/Hack%20$v%20Nerd%20Font%20Complete.ttf"
        curl -fLo "$ttf" "$url"
      done
    fi
    ;;
  solaris*) ;;
  bsd*)     ;;
  msys*)    ;;
  cygwin*)  ;;
  *) echo "unknown: $OSTYPE" ;;
esac

