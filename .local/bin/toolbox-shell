#!/usr/bin/env bash
#
# toolbox-shell starts or connects to tmux session 0.
# Its primary use is as a custom command for gnome-terminal.

set -euo pipefail

cfg="${XDG_CONFIG_HOME:-$HOME/.config}/toolbox/toolbox-shell-setup"

if [[ ! -f "$cfg" ]]; then
  toolbox create --assumeyes &>/dev/null || true
  toolbox_vscode="$HOME/.local/share/toolbox-vscode"
  toolbox run bash -c 'sudo ln -sf '"$toolbox_vscode"'/code.sh /usr/local/bin/code' &>/dev/null
  toolbox run bash -c 'sudo ln -sf '"$toolbox_vscode"'/podman-host.sh /usr/local/bin/podman' &>/dev/null
  toolbox run bash -c 'sudo dnf -q install -y fish neovim tmux git curl htop' &>/dev/null
  touch "$cfg"
fi

shell="$(getent passwd "$(id -u)" | awk -F: '{ print $7  }')"
exec toolbox run "$shell" -c 'tmux new -As0'
