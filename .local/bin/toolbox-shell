#!/usr/bin/env bash
#
# toolbox-shell starts or connects to tmux session 0.
# It is meant to be used as a custom command for gnome-terminal, vscode, etc.

set -euo pipefail

cfg="${XDG_CONFIG_HOME:-$HOME/.config}/toolbox/tools-setup"

if [[ ! -f "$cfg" ]]; then
  toolbox create --assumeyes &>/dev/null || true
  podman_host="$HOME/.local/share/podman-host.sh"
  toolbox run bash -c 'sudo ln -sf '"$podman_host"' /usr/local/bin/podman' &>/dev/null
  toolbox run bash -c 'sudo dnf -q install -y fish neovim tmux git curl htop' &>/dev/null
  touch "$cfg"
fi

shell="$(getent passwd "$(id -u)" | awk -F: '{ print $7  }')"
exec toolbox run "$shell" -c 'tmux new -As0'
